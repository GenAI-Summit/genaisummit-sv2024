ol items-start justify-center gap-y-1 text-color5","children":[["$","p",null,{"className":"font-bold md:text-[14px] text-[8px]","children":"Arvind Jain"}],["$","p",null,{"className":"md:text-[12px] text-[7px]","children":"Founder & CEO"}],["$","p",null,{"className":"md:text-[12px] text-[7px]","children":["@","Glean"]}]]}]]}],["$","div","40779243",{"className":"w-1/4 md:w-[16%] border_border__5GhuZ","children":[["$","$L17","40779243",{"speaker":{"id":40779243,"name":"Jim Fan","title":"Research Manager & Lead of Embodied AI","organization":"NVIDIA","bio":"Dr. Jim Fan is a Senior Research Scientist at NVIDIA and leads the AI Agents Initiative, focusing on developing versatile agents for both real and simulated environments. His expertise spans multimodal foundation models, reinforcement learning, and computer vision. With a Ph.D. from Stanford Vision Lab under Prof. Fei-Fei Li, Jim has interned at OpenAI, Baidu AI Labs, and MILA, contributing to AI research alongside leaders like Ilya Sutskever and Yoshua Bengio. As a Columbia University Valedictorian, he was awarded the Illig Medal in 2016.","avatar":"https://d1keuthy5s86c8.cloudfront.net/genai_202405/b423e8a105e4c27296cbab4af5d56cc1712d5ebece0ef6ef3f2765093a3b669c_1/cropped_img_genai_202405_1723143518252.png","session_role":""}}],["$","div",null,{"className":"mt-2 flex flex-col items-start justify-center gap-y-1 text-color5","children":[["$","p",null,{"className":"font-bold md:text-[14px] text-[8px]","children":"Jim Fan"}],["$","p",null,{"className":"md:text-[12px] text-[7px]","children":"Research Manager & Lead of Embodied AI"}],["$","p",null,{"className":"md:text-[12px] text-[7px]","children":["@","NVIDIA"]}]]}]]}],["$","div","40779264",{"className":"w-1/4 md:w-[16%] border_border__5GhuZ","children":[["$","$L17","40779264",{"speaker":{"id":40779264,"name":"Jon Shalowitz","title":"Managing Director","organization":"Woodside Capital Partners","bio":"Jon advises AI and Cloud Infrastructure & Software companies on M&A and strategic financing. With over 25 years of Silicon Valley experience, he's successfully led exits for startups like LiftIgniter, Badgeville, CloudUp Networks, and XDN. Prior to WCP, he held CEO roles and worked at Internet infrastructure giants like 3Com and NetScreen/Juniper. A Phi Beta Kappa graduate of Duke University and Stanford Graduate School of Business alum.","avatar":"https://d1keuthy5s86c8.cloudfront.net/genai_202405/6a1d9a71697f3dc70549dc0885fd64dca001d0815ee6f3c89ae6144e46b9c19a_1/cropped_img_genai_202405_1723143542950.png","session_role":""}}],["$","div",null,{"className":"mt-2 flex flex-col items-start justify-center gap-y-1 text-color5","children":[["$","p",null,{"className":"font-bold md:text-[14px] text-[8px]","children":"Jon Shalowitz"}],["$","p",null,{"className":"md:text-[12px] text-[7px]","children":"Managing Director"}],["$","p",null,{"className":"md:text-[12px] text-[7px]","children":["@","Woodside Capital Partners"]}]]}]]}],["$","div","40779536",{"className":"w-1/4 md:w-[16%] border_border__5GhuZ","children":[["$","$L17","40779536",{"speaker":{"id":40779536,"name":"Yiran Chen","title":"Professor","organization":"Duke University","bio":"Dr. Yiran Chen is the John Cocke Distinguished Professor of Electrical and Computer Engineering at Duke University. He directs the NSF AI Institute for Edge Computing Leveraging Next-generation Networks (Athena) and the NSF Industry-University Cooperative Research Center (IUCRC) for Alternative Sustainable and Intelligent Computing (ASIC). Dr. Chen's research focuses on memory systems, machine learning, and mobile computing. He has published over 600 technical papers, holds 96 US patents, and has received numerous awards for his contributions. A Fellow of AAAS, ACM, IEEE, and NAI, Dr. Chen is a leading voice in responsible AI use and academic equality.","avatar":"https://d1keuthy5s86c8.cloudfront.net/genai_202405/9d184ea3682fb569aeaa38d33a8de11489200cfec42df85c8b3b32ca296e6eb2_1/cropped_img_genai_202405_1723143507044.png","session_role":""}}],["$","div",null,{"className":"mt-2 flex flex-col items-start justify-center gap-y-1 text-color5","children":[["$","p",null,{"className":"font-bold md:text-[14px] text-[8px]","children":"Yiran Chen"}],["$","p",null,{"className":"md:text-[12px] text-[7px]","children":"Professor"}],["$","p",null,{"className":"md:text-[12px] text-[7px]","children":["@","Duke University"]}]]}]]}],["$","div","40779448",{"className":"w-1/4 md:w-[16%] border_border__5GhuZ","children":[["$","$L17","40779448",{"speaker":{"id":40779448,"name":"Fan Zhang","title":"Co-Founder","organization":"Sequoia Capital China","bio":"Fan Zhang is a renowned venture capitalist and co-founder of Sequoia Capital China, one of the most influential VC firms in the country. He has over 25 years of experience investing in innovative companies across various sectors, including internet, semiconductor, blockchain, AI, and spatial computing. Zhang played a pivotal role in establishing Sequoia Capital China in 2005 and helped raise billions for its funds, backing numerous successful startups that went public.","avatar":"https://d1keuthy5s86c8.cloudfront.net/genai_202405/6303f757ee3ef96a24d894b80386edb2496e295a5f9dd72d4974d0e28db929ba_1/cropped_img_genai_202405_1723143552994.png","session_role":""}}],["$","div",null,{"className":"mt-2 flex flex-col items-start justify-center gap-y-1 text-color5","children":[["$","p",null,{"className":"font-bold md:text-[14px] text-[8px]","children":"Fan Zhang"}],["$","p",null,{"className":"md:text-[12px] text-[7px]","children":"Co-Founder"}],["$","p",null,{"className":"md:text-[12px] text-[7px]","children":["@","Sequoia Capital China"]}]]}]]}]]}],["$","div",null,{"className":"mt-4","children":["$","$L16",null,{"target":"/speakers","text":"View All Speakers"}]}]]}]]}]
